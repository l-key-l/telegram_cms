DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

# 本项目固定使用 MySQL，不提供 SQLite 回退
DB_NAME=telegram
DB_USER=telegram_manager
DB_PASSWORD=replace-me
DB_HOST=127.0.0.1
DB_PORT=3306

# 使用 Fernet.generate_key() 生成；生产环境必须固定并安全保存
BOT_TOKEN_ENCRYPTION_KEY=
PRODUCT_NAME=Telegram 频道管理
PUBLIC_BASE_URL=https://你的域名
# 本地网络需要代理访问 Telegram 时填写，例如 http://127.0.0.1:7897
TELEGRAM_PROXY_URL=
OPERATION_WORKER_POLL_SECONDS=0.5
EMBEDDED_WORKER=1
